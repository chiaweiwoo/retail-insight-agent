# ── LLM ──────────────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-your-key-here
LLM_BASE_URL=https://api.deepseek.com

# Model routing: flash = high-volume/mechanical, deep = synthesis/judgment
DEEPSEEK_MODEL_FAST=deepseek-v4-flash
DEEPSEEK_MODEL_DEEP=deepseek-v4-pro

# ── Supabase (backend — service key bypasses RLS, never expose to browser) ───
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# Anon key — safe for dashboard reads (enforced by RLS policies)
SUPABASE_ANON_KEY=your-anon-key-here

# ── Langfuse observability (Round 2) ─────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-your-key-here
LANGFUSE_SECRET_KEY=sk-lf-your-key-here
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Feature flags ─────────────────────────────────────────────────────────────
# Set to true to enable web research (DuckDuckGo) during runs
RCA_RESEARCH_ENABLED=false
